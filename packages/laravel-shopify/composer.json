{
    "name": "amadulhaque/laravel-shopify",
    "description": "Production-grade multi-tenant Shopify integration for Laravel (GraphQL-first OAuth, API client, webhooks, billing).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "shopify",
        "graphql",
        "oauth",
        "multi-tenant",
        "ecommerce"
    ],
    "authors": [
        {
            "name": "Amadul Haque"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/console": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "AmadulHaque\\LaravelShopify\\": "src/",
            "AmadulHaque\\LaravelShopify\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AmadulHaque\\LaravelShopify\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AmadulHaque\\LaravelShopify\\Providers\\ShopifyServiceProvider"
            ],
            "aliases": {
                "Shopify": "AmadulHaque\\LaravelShopify\\Facades\\Shopify"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
